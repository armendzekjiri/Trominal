APP_NAME=Trominal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=55432
DB_DATABASE=trominal
DB_USERNAME=trominal
DB_PASSWORD=trominal

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

TROMINAL_REGISTRATION_MODE=single
TROMINAL_ACCESS_TOKEN_EXPIRATION_MINUTES=15
TROMINAL_REFRESH_TOKEN_EXPIRATION_DAYS=30
TROMINAL_WEB_SSH_PROXY_HOST=127.0.0.1
TROMINAL_WEB_SSH_PROXY_PORT=8080
TROMINAL_WEB_SSH_PROXY_PATH=/ws/ssh
# Optional externally visible URL when the SSH WebSocket proxy is not served
# from APP_URL's host. Example: ws://127.0.0.1:8080/ws/ssh
TROMINAL_WEB_SSH_PROXY_URL=

# Comma-separated list of origins allowed to call /api/* (CORS).
# Defaults cover the local Tauri/Vite ports for dev. In production this should
# be the deployed client origin(s).
ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
