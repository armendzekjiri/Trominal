TROMINAL_BACKEND_IMAGE=trominal-backend:local
TROMINAL_SITE_ADDRESS=:80
HTTP_PORT=80
HTTPS_PORT=443

APP_NAME=Trominal
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=info

POSTGRES_DB=trominal
POSTGRES_USER=trominal
POSTGRES_PASSWORD=change-me

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=trominal
DB_USERNAME=trominal
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Trominal

ALLOWED_ORIGINS=http://localhost,tauri://localhost
TROMINAL_REGISTRATION_MODE=single
TROMINAL_BACKEND_VERSION=dev
TROMINAL_API_VERSION=v1
TROMINAL_MIN_CLIENT_VERSION=0.1.0
TROMINAL_ACCESS_TOKEN_EXPIRATION_MINUTES=15
TROMINAL_REFRESH_TOKEN_EXPIRATION_DAYS=30
TROMINAL_WEB_SSH_PROXY_HOST=0.0.0.0
TROMINAL_WEB_SSH_PROXY_PORT=8080
TROMINAL_WEB_SSH_PROXY_PATH=/ws/ssh
TROMINAL_WEB_SSH_PROXY_URL=
